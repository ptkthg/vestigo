# ─── Segredos internos ────────────────────────────────────────────────────────
# Segredo compartilhado entre containers para autenticação inter-serviço.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_SECRET=troque_por_valor_gerado_aleatorio

# ─── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_DB=vestigo
POSTGRES_USER=vestigo
POSTGRES_PASSWORD=troque_por_senha_forte

# ─── APIs de enriquecimento ────────────────────────────────────────────────────
# AbuseIPDB: https://www.abuseipdb.com/account/api
# Plano gratuito: 1.000 checks/dia
ABUSEIPDB_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey
# Plano gratuito: 4 requests/min, 500/dia
VIRUSTOTAL_API_KEY=

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "groq" | "openai" | "ollama"
LLM_PROVIDER=groq

# Groq (recomendado — gratuito): https://console.groq.com/keys
# Modelo: llama-3.3-70b-versatile
GROQ_API_KEY=

# OpenAI (alternativa): https://platform.openai.com/api-keys
# Modelo: gpt-4o
OPENAI_API_KEY=

# ─── Ollama (LLM 100% local, sem internet) ────────────────────────────────────
# Para usar: defina LLM_PROVIDER=ollama e suba com:
#   docker-compose --profile ollama up
#
# Modelos recomendados (primeira execução baixa automaticamente):
#   qwen2.5:7b    — 4.4 GB, recomendado (melhor JSON estruturado, ideal para o Vestigo)
#   llama3.2:3b   — 2.0 GB, mais leve, para máquinas com menos RAM
#   llama3.1:8b   — 4.7 GB, alternativa llama
#   mistral:7b    — 4.1 GB, alternativa sólida
OLLAMA_MODEL=qwen2.5:7b

# ─── Gateway ──────────────────────────────────────────────────────────────────
# Requisições por minuto por IP na API de entrada
RATE_LIMIT_PER_MINUTE=10

# ─── Alertas por Webhook ──────────────────────────────────────────────────────
# URL para receber alertas automáticos (Slack, Teams, ou webhook genérico)
# Slack:  https://hooks.slack.com/services/...
# Teams:  https://outlook.office.com/webhook/...
WEBHOOK_URL=

# Severidade mínima para disparar o webhook: low | medium | high | critical
WEBHOOK_MIN_SEVERITY=high
